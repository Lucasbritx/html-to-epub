{
  "name": "html-to-epub",
  "version": "1.0.0",
  "description": "CLI tool to convert multi-page HTML websites into clean EPUB files",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "html-to-epub": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "epub",
    "html",
    "converter",
    "ebook",
    "kindle",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "commander": "^12.1.0",
    "consola": "^3.2.3",
    "epub-gen-memory": "^1.0.10",
    "p-limit": "^6.1.0",
    "playwright": "^1.48.0",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
